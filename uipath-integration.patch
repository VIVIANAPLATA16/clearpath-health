+# ====================================================================
+# ClearPath Health — UiPath Orchestrator Integration (Client Credentials)
+# ====================================================================
+# Copia este archivo como .env.local (que ya está en .gitignore) y
+# completa los valores reales. NUNCA subas .env.local a GitHub.
+
+# Dominio base de tu organización en UiPath (staging para este hackathon)
+UIPATH_BASE_URL=https://staging.uipath.com
+
+# Nombre de tu organización (lo ves en la URL: staging.uipath.com/<ORG_NAME>/...)
+UIPATH_ORG_NAME=hackathon26_724
+
+# Nombre del tenant (lo ves en la URL de Orchestrator)
+UIPATH_TENANT_NAME=DefaultTenant
+
+# Credenciales de la app OAuth "ClearPath-Health-NextJS" (Confidential, Client Credentials)
+UIPATH_CLIENT_ID=b5704f09-ba65-4b6d-9b63-e261c387ca29
+UIPATH_CLIENT_SECRET=pega_aqui_tu_app_secret_real
+
+# Folder ID donde vive la Queue (lo ves en la URL de Orchestrator como ?fid=XXXXXXX)
+UIPATH_FOLDER_ID=3087932
+
+# Nombre de la Queue creada en Orchestrator
+UIPATH_QUEUE_NAME=ClearPathAuthorizations
+
+# Scopes solicitados al pedir el access token (deben coincidir con los configurados en la app OAuth)
+UIPATH_SCOPE=OR.Queues OR.Queues.Read OR.Assets OR.Assets.Read OR.Execution OR.Jobs
