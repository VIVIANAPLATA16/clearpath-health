+/**
+ * Cliente para interactuar con la API de Queues de UiPath Orchestrator.
+ * Usa el access token obtenido vía Client Credentials (lib/uipath/auth.ts)
+ * para crear un QueueItem por cada solicitud de autorización procesada,
+ * dejando un registro real y auditable en UiPath Orchestrator.
+ */
+
+import { getUiPathAccessToken, getUiPathConfigOrThrow, UiPathAuthError } from "./auth"
+
+export class UiPathQueueError extends Error {
+  constructor(message: string, public readonly cause?: unknown) {
+    super(message)
+    this.name = "UiPathQueueError"
+  }
+}
+
+export type AuthorizationQueueItem = {
+  caseId: string
+  patientName: string
+  patientAge: string
+  diagnosis: string
+  service: string
+  eps: string
+  score: number
+  approved: boolean
+  reasoning: string
+}
+
+export type QueueItemResult = {
+  queueItemId: number
+  status: string
+}
+
+/**
+ * Crea un nuevo item en la Queue ClearPathAuthorizations de Orchestrator.
+ * Lanza UiPathQueueError o UiPathAuthError si algo falla; el llamador
+ * (app/api/process/route.ts) decide si cae al Fail-Safe Mode local.
+ */
+export async function addAuthorizationQueueItem(
+  item: AuthorizationQueueItem,
+): Promise<QueueItemResult> {
+  const config = getUiPathConfigOrThrow()
+  const token = await getUiPathAccessToken()
+
+  const url = `${config.baseUrl}/${config.orgName}/${config.tenantName}/orchestrator_/odata/Queues/UiPathODataSvc.AddQueueItem`
+
+  const payload = {
+    itemData: {
+      Name: config.queueName,
+      Priority: item.approved ? "Normal" : "High",
+      Reference: item.caseId,
+      SpecificContent: {
+        CaseId: item.caseId,
+        PatientName: item.patientName,
+        PatientAge: item.patientAge,
+        Diagnosis: item.diagnosis,
+        Service: item.service,
+        Eps: item.eps,
+        PertinenceScore: item.score,
+        Approved: item.approved,
+        Reasoning: item.reasoning,
+      },
+    },
+  }
+
+  let response: Response
+  try {
+    response = await fetch(url, {
+      method: "POST",
+      headers: {
+        "Content-Type": "application/json",
+        Authorization: `Bearer ${token}`,
+        "X-UIPATH-OrganizationUnitId": config.folderId,
+        Accept: "application/json",
+      },
+      body: JSON.stringify(payload),
+      signal: AbortSignal.timeout(8000),
+    })
+  } catch (err) {
+    throw new UiPathQueueError("No se pudo contactar a UiPath Orchestrator", err)
+  }
+
+  if (!response.ok) {
+    const errorText = await response.text().catch(() => "")
+    throw new UiPathQueueError(
+      `Orchestrator respondió ${response.status}: ${errorText.slice(0, 300)}`,
+    )
+  }
+
+  const data = (await response.json()) as { Id: number; Status: string }
+  return { queueItemId: data.Id, status: data.Status }
+}
+
+export { UiPathAuthError }
