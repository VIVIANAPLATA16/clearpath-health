+++ b/lib/uipath/auth.ts
@@ -0,0 +1,112 @@
+/**
+ * Cliente de autenticación OAuth 2.0 Client Credentials contra UiPath
+ * Identity Server. Usado por el backend (Next.js API routes) para obtener
+ * un access token machine-to-machine y llamar a la API de Orchestrator
+ * (Queues) sin intervención de un usuario humano.
+ *
+ * El token se cachea en memoria del proceso del servidor mientras sea
+ * válido, para evitar pedir un token nuevo en cada solicitud.
+ */
+
+type TokenCache = {
+  accessToken: string
+  expiresAt: number // epoch ms
+}
+
+let cachedToken: TokenCache | null = null
+
+export class UiPathAuthError extends Error {
+  constructor(message: string, public readonly cause?: unknown) {
+    super(message)
+    this.name = "UiPathAuthError"
+  }
+}
+
+function getUiPathConfig() {
+  const baseUrl = process.env.UIPATH_BASE_URL || "https://staging.uipath.com"
+  const orgName = process.env.UIPATH_ORG_NAME
+  const tenantName = process.env.UIPATH_TENANT_NAME || "DefaultTenant"
+  const clientId = process.env.UIPATH_CLIENT_ID
+  const clientSecret = process.env.UIPATH_CLIENT_SECRET
+  const folderId = process.env.UIPATH_FOLDER_ID
+  const queueName = process.env.UIPATH_QUEUE_NAME || "ClearPathAuthorizations"
+  const scope =
+    process.env.UIPATH_SCOPE ||
+    "OR.Queues OR.Queues.Read OR.Assets OR.Assets.Read OR.Execution OR.Jobs"
+
+  if (!orgName || !clientId || !clientSecret || !folderId) {
+    return null
+  }
+
+  return { baseUrl, orgName, tenantName, clientId, clientSecret, folderId, queueName, scope }
+}
+
+export function isUiPathConfigured(): boolean {
+  return getUiPathConfig() !== null
+}
+
+/**
+ * Obtiene un access token válido, reutilizando el cacheado en memoria si
+ * todavía no expiró (con 30s de margen de seguridad).
+ */
+export async function getUiPathAccessToken(): Promise<string> {
+  const config = getUiPathConfig()
+  if (!config) {
+    throw new UiPathAuthError("UiPath no está configurado (faltan variables de entorno)")
+  }
+
+  const now = Date.now()
+  if (cachedToken && cachedToken.expiresAt - 30_000 > now) {
+    return cachedToken.accessToken
+  }
+
+  const tokenUrl = `${config.baseUrl}/${config.orgName}/identity_/connect/token`
+
+  const body = new URLSearchParams({
+    grant_type: "client_credentials",
+    client_id: config.clientId,
+    client_secret: config.clientSecret,
+    scope: config.scope,
+  })
+
+  let response: Response
+  try {
+    response = await fetch(tokenUrl, {
+      method: "POST",
+      headers: { "Content-Type": "application/x-www-form-urlencoded" },
+      body: body.toString(),
+      // Evita que una llamada de auth colgada bloquee el flujo de la demo.
+      signal: AbortSignal.timeout(8000),
+    })
+  } catch (err) {
+    throw new UiPathAuthError("No se pudo contactar al Identity Server de UiPath", err)
+  }
+
+  if (!response.ok) {
+    const errorText = await response.text().catch(() => "")
+    throw new UiPathAuthError(
+      `Identity Server respondió ${response.status}: ${errorText.slice(0, 300)}`,
+    )
+  }
+
+  const data = (await response.json()) as {
+    access_token: string
+    expires_in: number
+    token_type: string
+  }
+
+  cachedToken = {
+    accessToken: data.access_token,
+    expiresAt: now + data.expires_in * 1000,
+  }
+
+  return cachedToken.accessToken
+}
+
+export function getUiPathConfigOrThrow() {
+  const config = getUiPathConfig()
+  if (!config) {
+    throw new UiPathAuthError("UiPath no está configurado (faltan variables de entorno)")
+  }
+  return config
+}
