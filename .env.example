# ====================================================================
# ClearPath Health — UiPath Orchestrator Integration (Client Credentials)
# ====================================================================
# Copy this file to .env.local (already in .gitignore) and fill in real values.
# NEVER commit .env.local to version control.

# UiPath Automation Cloud base URL (staging for AgentHack 2026)
UIPATH_BASE_URL=https://staging.uipath.com

# Organization name (visible in URL: staging.uipath.com/<ORG>/...)
UIPATH_ORGANIZATION_NAME=your_org_name

# Tenant name (visible in Orchestrator URL)
UIPATH_TENANT_NAME=DefaultTenant

# OAuth2 External Application credentials (Confidential, Client Credentials)
UIPATH_CLIENT_ID=your_app_id_here
UIPATH_CLIENT_SECRET=your_app_secret_here

# Orchestrator folder ID (from URL ?fid=XXXXXXX)
UIPATH_FOLDER_ID=your_folder_id

# Queue name created in Orchestrator
UIPATH_QUEUE_NAME=ClearPathAuthorizations
